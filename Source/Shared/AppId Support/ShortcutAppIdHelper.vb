                propVariant.wReserved1 = 0US
                propVariant.wReserved2 = 0US
                propVariant.wReserved3 = 0US
                propVariant.pointerValue = IntPtr.Zero

                Dim key As PropertyKey = PKEY_AppUserModel_ID
                propertyStore.SetValue(key, propVariant)
                propertyStore.Commit()

            Catch ex As Exception
                Throw New InvalidOperationException($"Failed to clear AppUserModelID from shortcut: {shortcutPath}", ex)

            Finally
                If propertyStore IsNot Nothing AndAlso Marshal.IsComObject(propertyStore) Then
                    Marshal.FinalReleaseComObject(propertyStore)
                End If

#Disable Warning IDE0059 ' Unnecessary assignment of a value
                propertyStore = Nothing
                propertyStoreObj = Nothing
#Enable Warning IDE0059 ' Unnecessary assignment of a value
                GC.Collect()
                GC.WaitForPendingFinalizers()
                GC.Collect()
            End Try
        End Sub

    ''' 
    ''' <summary>
    ''' Enumerates every application registered under the Windows <c>shell:AppsFolder</c> virtual folder
    ''' and returns its display name together with its <c>AppUserModelID</c>.
    ''' <para></para>
    ''' This is the native equivalent of the PowerShell <c>Get-StartApps</c> cmdlet.
    ''' </summary>
    ''' 
    ''' <returns>
    ''' A list of <see cref="InstalledAppInfo"/> entries, one per registered application that exposes an
    ''' <c>AppUserModelID</c>. The list is empty if no application is found.
    ''' </returns>
    ''' 
    ''' <exception cref="InvalidOperationException">
    ''' Thrown if the enumeration of <c>shell:AppsFolder</c> fails.
    ''' </exception>
    ''' 
    Public Shared Function GetInstalledAppUserModelIds() As List(Of InstalledAppInfo)
            Dim result As New List(Of InstalledAppInfo)()

            Dim appsFolderObj As Object = Nothing
            Dim appsFolder As IShellItem = Nothing
            Dim enumObj As Object = Nothing
            Dim enumItems As IEnumShellItems = Nothing

            Try
                Dim iidShellItem As Guid = IID_IShellItem
                SHCreateItemFromParsingName("shell:AppsFolder", IntPtr.Zero, iidShellItem, appsFolderObj)
                appsFolder = DirectCast(appsFolderObj, IShellItem)

                Dim bhid As Guid = BHID_EnumItems
                Dim iidEnum As Guid = IID_IEnumShellItems
                appsFolder.BindToHandler(IntPtr.Zero, bhid, iidEnum, enumObj)
                enumItems = DirectCast(enumObj, IEnumShellItems)

                Do
                    Thread.CurrentThread.Join(0)

                    Dim item As IShellItem = Nothing
                    Dim fetched As UInteger = 0UI
                    Dim hr As Integer = enumItems.Next(1UI, item, fetched)

                    If hr <> 0 OrElse fetched = 0UI OrElse item Is Nothing Then
                        Exit Do
                    End If

                    Dim item2 As IShellItem2 = Nothing
                    Try
                        item2 = DirectCast(item, IShellItem2)

                        Dim appIdValue As String = Nothing
                        Try
                            Dim keyAppId As PropertyKey = PKEY_AppUserModel_ID
                            item2.GetString(keyAppId, appIdValue)
                        Catch comEx As COMException When comEx.ErrorCode = E_ELEMENTNOTFOUND
                            appIdValue = Nothing
                        End Try

                        Dim nameValue As String = Nothing
                        Try
                            ' SIGDN_NORMALDISPLAY = 0
                            item2.GetDisplayName(0UI, nameValue)
                        Catch
                            nameValue = String.Empty
                        End Try

                        If Not String.IsNullOrEmpty(appIdValue) Then
                            result.Add(New InstalledAppInfo(If(nameValue, String.Empty), appIdValue))
                        End If

                    Finally
                        If item IsNot Nothing AndAlso Marshal.IsComObject(item) Then
                            Marshal.FinalReleaseComObject(item)
                        End If
                    End Try
                Loop

                Return result

            Catch ex As Exception
                Throw New InvalidOperationException("Failed to enumerate installed AppUserModelIDs from shell:AppsFolder.", ex)

            Finally
                If enumItems IsNot Nothing AndAlso Marshal.IsComObject(enumItems) Then
                    Marshal.FinalReleaseComObject(enumItems)
                End If
                If appsFolder IsNot Nothing AndAlso Marshal.IsComObject(appsFolder) Then
                    Marshal.FinalReleaseComObject(appsFolder)
                End If
            End Try
        End Function

