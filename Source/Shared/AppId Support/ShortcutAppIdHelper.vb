    ''' 
    ''' <summary>
    ''' Reads the <c>AppUserModelID</c> from the specified shortcut (<c>.lnk</c>) file.
    ''' </summary>
    ''' 
    ''' <param name="shortcutPath">
    ''' The full path of the shortcut file.
    ''' </param>
    ''' 
    ''' <returns>
    ''' The <c>AppUserModelID</c> string stored in the shortcut's <c>PropertyStore</c>,
    ''' or <see langword="Nothing"/> if the property is not present.
    ''' </returns>
    ''' 
    ''' <exception cref="ArgumentNullException">
    ''' Thrown if <paramref name="shortcutPath"/> is <see langword="Nothing"/> or an empty string.
    ''' </exception>
    ''' 
    ''' <exception cref="FileNotFoundException">
    ''' Thrown if the specified shortcut file does not exist.
    ''' </exception>
    ''' 
    ''' <exception cref="InvalidOperationException">
    ''' Thrown if the underlying Shell API call fails for an unexpected reason.
    ''' </exception>
    ''' 
    Public Shared Function GetAppUserModelId(shortcutPath As String) As String
            If String.IsNullOrEmpty(shortcutPath) Then
                Throw New ArgumentNullException(NameOf(shortcutPath))
            End If
            If Not File.Exists(shortcutPath) Then
                Throw New FileNotFoundException($"The specified shortcut file is not found: {shortcutPath}", shortcutPath)
            End If

            Dim shellItemObj As Object = Nothing
            Dim shellItem2 As IShellItem2 = Nothing
            Try
                Dim iid As Guid = IID_IShellItem2
                SHCreateItemFromParsingName(shortcutPath, IntPtr.Zero, iid, shellItemObj)
                shellItem2 = DirectCast(shellItemObj, IShellItem2)

                Dim key As PropertyKey = PKEY_AppUserModel_ID
                Dim appId As String = Nothing
                shellItem2.GetString(key, appId)
                Return appId

            Catch comEx As COMException When comEx.ErrorCode = E_ELEMENTNOTFOUND
                ' The property is not set on this shortcut.
                Return Nothing

            Catch ex As Exception
                Throw New InvalidOperationException($"Failed to read AppUserModelID from shortcut: {shortcutPath}", ex)

            Finally
                If shellItem2 IsNot Nothing AndAlso Marshal.IsComObject(shellItem2) Then
                    Marshal.FinalReleaseComObject(shellItem2)
                End If

#Disable Warning IDE0059 ' Unnecessary assignment of a value
                shellItem2 = Nothing
                shellItemObj = Nothing
#Enable Warning IDE0059 ' Unnecessary assignment of a value
                GC.Collect()
                GC.WaitForPendingFinalizers()
                GC.Collect()
            End Try
        End Function

    ''' 
    ''' <summary>
    ''' Writes (or overwrites) the <c>AppUserModelID</c> of the specified shortcut (<c>.lnk</c>) file.
    ''' </summary>
    ''' 
    ''' <param name="shortcutPath">
    ''' The full path of the shortcut file.
    ''' </param>
    ''' 
    ''' <param name="appId">
    ''' The new <c>AppUserModelID</c> to assign to the shortcut.
    ''' </param>
    ''' 
    ''' <exception cref="ArgumentNullException">
    ''' Thrown if <paramref name="shortcutPath"/> or <paramref name="appId"/> is <see langword="Nothing"/>.
    ''' </exception>
    ''' 
    ''' <exception cref="FileNotFoundException">
    ''' Thrown if the specified shortcut file does not exist.
    ''' </exception>
    ''' 
    ''' <exception cref="InvalidOperationException">
    ''' Thrown if the underlying Shell API call fails to commit the new value.
    ''' </exception>
    ''' 
    Public Shared Sub SetAppUserModelId(shortcutPath As String, appId As String)

        If String.IsNullOrEmpty(shortcutPath) Then
            Throw New ArgumentNullException(NameOf(shortcutPath))
        End If
        If appId Is Nothing Then
            Throw New ArgumentNullException(NameOf(appId))
        End If
        If Not File.Exists(shortcutPath) Then
            Throw New FileNotFoundException($"The specified shortcut file is not found: {shortcutPath}", shortcutPath)
        End If

        Dim propertyStoreObj As Object = Nothing
        Dim propertyStore As IPropertyStore = Nothing
        Dim propVariant As New PropVariantNative()
        Dim stringPtr As IntPtr = IntPtr.Zero
        Dim mustFreeString As Boolean = False

        Try
            Dim iid As Guid = IID_IPropertyStore
            Dim hr As Integer = SHGetPropertyStoreFromParsingName(shortcutPath, IntPtr.Zero, GPS_READWRITE, iid, propertyStoreObj)
            If hr <> 0 Then
                Throw New Win32Exception(hr, $"SHGetPropertyStoreFromParsingName failed with HRESULT 0x{hr:X8}.")
            End If

            propertyStore = DirectCast(propertyStoreObj, IPropertyStore)

            ' Manually build a VT_LPWSTR PROPVARIANT.
            stringPtr = Marshal.StringToCoTaskMemUni(appId)
            mustFreeString = True

            propVariant.vt = CUShort(31) ' VT_LPWSTR
            propVariant.wReserved1 = 0US
            propVariant.wReserved2 = 0US
            propVariant.wReserved3 = 0US
            propVariant.pointerValue = stringPtr

            Dim key As PropertyKey = PKEY_AppUserModel_ID
            propertyStore.SetValue(key, propVariant)
            propertyStore.Commit()

            ' After SetValue+Commit succeed, PropVariantClear will release the string buffer.
            Try
                PropVariantClear(propVariant)
                mustFreeString = False
            Catch
                ' Fallback: free manually in the Finally block below.
            End Try

        Catch ex As Exception
            Throw New InvalidOperationException($"Failed to write AppUserModelID to shortcut: {shortcutPath}", ex)

        Finally
            If mustFreeString AndAlso stringPtr <> IntPtr.Zero Then
                Marshal.FreeCoTaskMem(stringPtr)
            End If
            If propertyStore IsNot Nothing AndAlso Marshal.IsComObject(propertyStore) Then
                Marshal.FinalReleaseComObject(propertyStore)
            End If

#Disable Warning IDE0059 ' Unnecessary assignment of a value
            propertyStore = Nothing
            propertyStoreObj = Nothing
#Enable Warning IDE0059 ' Unnecessary assignment of a value
            ' Force the Shell's property handler to release its internal file handle.
            ' Without this, a subsequent File.SetCreationTime / etc. on the same path
            ' throws IOException "file is being used by another process".
            GC.Collect()
            GC.WaitForPendingFinalizers()
            GC.Collect()
        End Try
    End Sub

