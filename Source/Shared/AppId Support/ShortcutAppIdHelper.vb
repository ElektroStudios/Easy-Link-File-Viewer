    ''' <exception cref="ArgumentNullException">
    ''' Thrown if <paramref name="shortcutPath"/> is <see langword="Nothing"/> or an empty string.
    ''' </exception>
    ''' 
    ''' <exception cref="FileNotFoundException">
    ''' Thrown if the specified shortcut file does not exist.
    ''' </exception>
    ''' 
    ''' <exception cref="InvalidOperationException">
    ''' Thrown if the underlying Shell API call fails to commit the removal.
    ''' </exception>
    ''' 
    Public Shared Sub ClearAppUserModelId(shortcutPath As String)
            If String.IsNullOrEmpty(shortcutPath) Then
                Throw New ArgumentNullException(NameOf(shortcutPath))
            End If
            If Not File.Exists(shortcutPath) Then
                Throw New FileNotFoundException($"The specified shortcut file is not found: {shortcutPath}", shortcutPath)
            End If

            Dim propertyStoreObj As Object = Nothing
            Dim propertyStore As IPropertyStore = Nothing
            Dim propVariant As New PropVariantNative()

            Try
                Dim iid As Guid = IID_IPropertyStore
                Dim hr As Integer = SHGetPropertyStoreFromParsingName(shortcutPath, IntPtr.Zero, GPS_READWRITE, iid, propertyStoreObj)
                If hr <> 0 Then
                    Throw New Win32Exception(hr, $"SHGetPropertyStoreFromParsingName failed with HRESULT 0x{hr:X8}.")
                End If

                propertyStore = DirectCast(propertyStoreObj, IPropertyStore)

                ' A zero-initialized PROPVARIANT has vt = VT_EMPTY (0), which signals
                ' "remove this property from the store".
